# ============================================
# SBC Preprod Environment Configuration
# ============================================
# Preprod services run on ports 6000-6008 (prod + 3000)
# Preprod databases use _preprod suffix
# Copy relevant sections to each service's .env in the preprod checkout
# ============================================

# ========== Root .env ==========
NODE_ENV=preprod
GLOBAL_MONGO_BASE_URI=mongodb://localhost:27017
GLOBAL_MONGO_BASE_URI_PROD=mongodb://your_mongo_host:27017
GCS_BUCKET_NAME=test-db-backup-sbc

# ========== Common Service URLs (preprod ports) ==========
# Copy these to each service's .env, adjusting as needed
USER_SERVICE_URL=http://localhost:6001
NOTIFICATION_SERVICE_URL=http://localhost:6002
PAYMENT_SERVICE_URL=http://localhost:6003
PRODUCT_SERVICE_URL=http://localhost:6004
ADVERTISING_SERVICE_URL=http://localhost:6005
TOMBOLA_SERVICE_URL=http://localhost:6006
SETTINGS_SERVICE_URL=http://localhost:6007
CHAT_SERVICE_URL=http://localhost:6008
API_GATEWAY_URL=http://localhost:6000

# ========== Gateway Service (port 6000) ==========
# PORT=6000
# HOST=0.0.0.0
# LOG_LEVEL=info
# CORS_ORIGIN=*
# SERVICE_SECRET=<same_as_prod>
# JWT_SECRET=<same_as_prod>

# ========== User Service (port 6001) ==========
# PORT=6001
# HOST=0.0.0.0
# MONGODB_URI_DEV=mongodb://localhost:27017/sbc_user_preprod
# MONGODB_URI_PROD=mongodb://your_mongo_host:27017/sbc_users_preprod
# JWT_SECRET=<same_as_prod>
# JWT_EXPIRATION=1d
# SERVICE_SECRET=<same_as_prod>
# SELF_BASE_URL=http://localhost:6001
# BODY_LIMIT=50mb
# CORS_ORIGIN=*
# DAILY_WITHDRAWAL_LIMIT=<same_as_prod>
# MAX_WITHDRAWALS_PER_DAY=<same_as_prod>
# LOG_LEVEL=info

# ========== Notification Service (port 6002) ==========
# PORT=6002
# MONGODB_URI_DEV=mongodb://localhost:27017/sbc_notification_preprod
# MONGODB_URI_PROD=mongodb://your_mongo_host:27017/sbc_notification_preprod
# JWT_SECRET=<same_as_prod>
# JWT_EXPIRATION=1d
# EMAIL_FROM=<same_as_prod>
# EMAIL_BOUNCE_HANDLING_ENABLED=<same_as_prod>
# INFO_EMAIL_USERNAME=<same_as_prod>
# INFO_EMAIL_APP_PASSWORD=<same_as_prod>
# EMAIL_SERVICE=<same_as_prod>
# EMAIL_USER=<same_as_prod>
# EMAIL_PASSWORD=<same_as_prod>
# TWILIO_ACCOUNT_SID=<same_as_prod>
# TWILIO_AUTH_TOKEN=<same_as_prod>
# TWILIO_PHONE_NUMBER=<same_as_prod>
# WHATSAPP_ENABLE_CLOUD_API=false  # Disable in preprod unless testing
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=2  # Different from prod (prod uses 0)
# FRONTEND_URL=https://preprod.sniperbuisnesscenter.com
# APP_LOGO_URL=<same_as_prod>
# SUPPORT_URL=<same_as_prod>
# QUEEN_SMS_API_KEY=<same_as_prod>
# QUEEN_SMS_API_URL=<same_as_prod>
# QUEEN_SMS_SENDER_ID=<same_as_prod>

# ========== Payment Service (port 6003) ==========
# PORT=6003
# MONGODB_URI_DEV=mongodb://localhost:27017/sbc_payment_preprod
# MONGODB_URI_PROD=mongodb://your_mongo_host:27017/sbc_payment_preprod
# JWT_SECRET=<same_as_prod>
# JWT_EXPIRES_IN=1d
# HOST=0.0.0.0
# SERVICE_SECRET=<same_as_prod>
# SELF_BASE_URL=http://localhost:6003
# PAYMENT_SERVICE_BASE_URL=https://preprod.sniperbuisnesscenter.com
# FRONTEND_URL=https://preprod.sniperbuisnesscenter.com
# FEEXPAY_API_KEY=<same_as_prod_or_test_key>
# FEEXPAY_SHOP_ID=<same_as_prod_or_test>
# FEEXPAY_BASE_URL=https://api.feexpay.me/api
# FEEXPAY_WEBHOOK_SECRET=<same_as_prod>
# WITHDRAWALS_ENABLED=false  # Disable withdrawals in preprod
# FEEXPAY_WITHDRAWALS_ENABLED=false
# CINETPAY_WITHDRAWALS_ENABLED=false
# NOWPAYMENTS_WITHDRAWALS_ENABLED=false
# CINETPAY_BASE_URL=<same_as_prod>
# CINETPAY_CM_API_KEY=<same_as_prod_or_test>
# CINETPAY_CM_API_PASSWORD=<same_as_prod_or_test>
# NOWPAYMENTS_API_KEY=<same_as_prod_or_test>
# NOWPAYMENTS_SANDBOX=true  # Use sandbox in preprod
# LOG_LEVEL=info

# ========== Product Service (port 6004) ==========
# PORT=6004
# HOST=0.0.0.0
# MONGODB_URI_DEV=mongodb://localhost:27017/sbc_products_preprod
# MONGODB_URI_PROD=mongodb://your_mongo_host:27017/sbc_products_preprod
# JWT_SECRET=<same_as_prod>
# JWT_EXPIRATION=1d
# SERVICE_SECRET=<same_as_prod>
# AWS_ACCESS_KEY_ID=<same_as_prod>
# AWS_SECRET_ACCESS_KEY=<same_as_prod>
# AWS_REGION=<same_as_prod>
# AWS_BUCKET_NAME=<same_as_prod_or_test>
# LOG_LEVEL=info

# ========== Tombola Service (port 6006) ==========
# PORT=6006
# HOST=0.0.0.0
# MONGODB_URI_DEV=mongodb://localhost:27017/sbc_tombola_preprod
# MONGODB_URI_PROD=mongodb://your_mongo_host:27017/sbc_tombola_preprod
# JWT_SECRET=<same_as_prod>
# JWT_EXPIRATION=1d
# SERVICE_SECRET=<same_as_prod>
# SELF_BASE_URL=http://localhost:6006
# LOG_LEVEL=info

# ========== Settings Service (port 6007) ==========
# PORT=6007
# MONGODB_URI_DEV=mongodb://localhost:27017/sbc_settings_preprod
# MONGODB_URI_PROD=mongodb://your_mongo_host:27017/sbc_settings_preprod
# JWT_SECRET=<same_as_prod>
# ACCESS_TOKEN_EXPIRY=1h
# REFRESH_TOKEN_EXPIRY=7d
# DRIVE_CLIENT_EMAIL=<same_as_prod>
# DRIVE_PRIVATE_KEY=<same_as_prod>
# DRIVE_SETTINGS_FOLDER_ID=<same_as_prod>
# PP_FOLDER=<same_as_prod>
# PD_FOLDER=<same_as_prod>
# SBC_FOLDER=<same_as_prod>
# ALLOWED_ORIGINS=*
# LOG_LEVEL=info

# ========== Chat Service (port 6008) ==========
# PORT=6008
# HOST=0.0.0.0
# MONGODB_URI_DEV=mongodb://localhost:27017/sbc_chat_preprod
# MONGODB_URI_PROD=mongodb://your_mongo_host:27017/sbc_chat_preprod
# JWT_SECRET=<same_as_prod>
# SERVICE_SECRET=<same_as_prod>
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=3  # Different from prod (prod uses 1)
# SELF_BASE_URL=http://localhost:6008
# LOG_LEVEL=info

# ========== Admin Frontend ==========
# VITE_API_URL=https://preprod.sniperbuisnesscenter.com/api
