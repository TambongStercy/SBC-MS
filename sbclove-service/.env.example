# Server Configuration
NODE_ENV=development
PORT=3009
HOST=0.0.0.0

# MongoDB Connection
MONGODB_URI_DEV=mongodb://localhost:27017/sbc_sbclove_dev
MONGODB_URI_PROD=

# JWT (must match the platform-wide secret used by user-service/gateway)
JWT_SECRET=sbc$$jwt$$secret
JWT_EXPIRATION=1d

# Service-to-service auth
SERVICE_SECRET=__REPLACE_WITH_STRONG_RANDOM_SECRET__

# Service URLs (the /api suffix is added automatically if missing)
USER_SERVICE_URL=http://localhost:3001/api
NOTIFICATION_SERVICE_URL=http://localhost:3002/api
SETTINGS_SERVICE_URL=http://localhost:3007/api
API_GATEWAY_URL=http://localhost:3000/api

# Self URL (for callbacks if needed)
SELF_BASE_URL=http://localhost:3009

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# --- SBCLOVE module configuration ---
# Weekly session window (Africa/Douala timezone)
SBCLOVE_TIMEZONE=Africa/Douala
SBCLOVE_ACTIVE_WEEKDAY=3          # 0=Sunday ... 3=Wednesday
SBCLOVE_OPEN_HOUR=18             # 18:00
SBCLOVE_CLOSE_HOUR=21            # 21:00
SBCLOVE_MAX_INTERESTS_PER_WEEK=5
SBCLOVE_AUTO_SUSPEND_THRESHOLD=3
# false = manual admin validation (recommended); true = auto-approve profiles that pass content checks
SBCLOVE_AUTO_APPROVE=false
SBCLOVE_MAX_PHOTOS=3
SBCLOVE_DESCRIPTION_MAX_LENGTH=300
SBCLOVE_OTHER_INTENTION_MAX_LENGTH=80
